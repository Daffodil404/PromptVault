<% content_for :title, "Log In" %>

<section class="page-header">
  <div>
    <h1>Log In</h1>
    <p>Access your account to manage prompts and reviews.</p>
  </div>
</section>

<section class="card form-card auth-card">
  <%= form_with url: login_path, local: true do |form| %>
    <div class="field">
      <%= form.label :email %>
      <%= form.email_field :email, required: true %>
    </div>

    <div class="field">
      <%= form.label :password %>
      <%= form.password_field :password, required: true %>
    </div>

    <div class="actions">
      <%= form.submit "Log in" %>
      <%= link_to "Need an account?", sign_up_path, class: "text-link" %>
    </div>
  <% end %>
</section>
